<?php
// 🔹 ЗАДАНИЕ 1: Создание переменных и вывод их типа
echo "<h2>Задание 1: Типы данных переменных</h2>";
$str = "Привет, мир!";    // Строка
$num = 42;                // Число
$bool = true;             // Логический тип
$empty = null;            // Null

echo "Строка: <b>$str</b>, тип: <i>" . gettype($str) . "</i><br>";
echo "Число: <b>$num</b>, тип: <i>" . gettype($num) . "</i><br>";
echo "Логический: <b>$bool</b>, тип: <i>" . gettype($bool) . "</i><br>";
echo "Null: <b>" . ($empty === null ? "NULL" : $empty) . "</b>, тип: <i>" . gettype($empty) . "</i><br>";
echo "<hr>";

// 🔹 ЗАДАНИЕ 2: Заголовок h1 с фамилией
